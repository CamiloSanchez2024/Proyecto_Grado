# Copia a .env en la raíz del repo o exporta estas variables antes de `docker compose up`.
# Valores por defecto definidos en docker-compose.yml si no se establecen.

# PostgreSQL (deben coincidir entre db y backend)
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=secure_api_db

# JWT y seguridad (cambiar en producción)
SECRET_KEY=reemplaza-por-un-secreto-largo-y-aleatorio
CLAVE_MAESTRA_AES=CAMBIAR_EN_PRODUCCION_CON_32_BYTES_MINIMO_1234

# Puertos publicados en el host
FRONTEND_PORT=5173
BACKEND_PORT=8000

# URL de API para Vite en Docker (modo desarrollo)
VITE_API_URL=http://localhost:8000/api/v1
